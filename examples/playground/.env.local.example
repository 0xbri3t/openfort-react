# Copy to .env.local — values from https://dashboard.openfort.io

VITE_OPENFORT_PUBLISHABLE_KEY=
VITE_SHIELD_PUBLISHABLE_KEY=

VITE_POLYGON_POLICY_ID=
VITE_BEAM_POLICY_ID=
VITE_BASE_POLICY_ID=

VITE_CREATE_ENCRYPTED_SESSION_ENDPOINT=
VITE_REQUEST_WALLET_RECOVER_OTP_ENDPOINT=

# Required for evm mode (WalletConnect)
VITE_WALLETCONNECT_PROJECT_ID=


# Mint contract addresses (chain-dependent)
VITE_BEAM_MINT_CONTRACT=
VITE_POLYGON_MINT_CONTRACT=

# Optional: Helius API key for Solana devnet airdrops (free at helius.dev)
# VITE_HELIUS_API_KEY=your-helius-api-key

# Optional overrides
VITE_API_URL=
VITE_IFRAME_API_URL=
VITE_SHIELD_URL=
