# Copy to .env.local — values from https://dashboard.openfort.io

# Required: Openfort project keys
VITE_OPENFORT_PUBLISHABLE_KEY=
VITE_SHIELD_PUBLISHABLE_KEY=

# Optional: Openfort service URL overrides (defaults are used if unset)
# VITE_API_URL=https://api.openfort.io
# VITE_SHIELD_URL=https://shield.openfort.io
# VITE_IFRAME_API_URL — SDK default is https://embed.openfort.io; only override for local development

# Required for AUTOMATIC wallet recovery: backend endpoint that creates an encryption session
# See: https://github.com/openfort-xyz/openfort-backend-quickstart
VITE_CREATE_ENCRYPTED_SESSION_ENDPOINT=

# Optional: backend endpoint for OTP-based wallet recovery
VITE_REQUEST_WALLET_RECOVER_OTP_ENDPOINT=

# Optional: WalletConnect project ID (for external wallet connections)
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: policy ID for sponsoring transactions
VITE_POLICY_ID=

# Optional: mint contract addresses (chain-dependent)
VITE_BEAM_MINT_CONTRACT=
VITE_POLYGON_MINT_CONTRACT=
